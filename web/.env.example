# Backend origin for production builds (Vite inlines VITE_* vars at build time).
# Leave EMPTY for local dev — requests use relative /api and the Vite proxy
# (vite.config.js) forwards them to http://localhost:8000.
#
# For a Vercel deploy, set this in the Vercel project's Environment Variables to
# your deployed backend origin, e.g.:
#   VITE_API_BASE=https://idea-validator-api.onrender.com
VITE_API_BASE=
